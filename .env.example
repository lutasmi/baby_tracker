# Copia este archivo a .env y rellena los valores de tu despliegue.
# Ninguno de estos valores es un secreto (ambos son visibles en el navegador),
# pero son distintos en cada despliegue y por eso no se versionan.

# URL del despliegue web de Google Apps Script (termina en /exec)
VITE_API_URL=

# Client ID de OAuth de Google (Google Cloud Console > Credenciales)
VITE_GOOGLE_CLIENT_ID=

# Opcional: usar la API simulada en memoria (sin Google) para desarrollo local.
# VITE_USE_MOCK=1
