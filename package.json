{
  "name": "baby_tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicación web móvil para registrar de forma rápida y compartida la actividad diaria de un bebé.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lutasmi/baby_tracker.git"
  },
